#include "resource.h"

#define APSTUDIO_READONLY_SYMBOLS
#include "winres.h"
#undef APSTUDIO_READONLY_SYMBOLS

IDD_OPTIONS_DIALOG DIALOGEX 0, 0, 260, 126
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Codex limit settings"
FONT 9, "Segoe UI", 400, 0, 0x0
BEGIN
    LTEXT           "5-hour usage (%):",IDC_STATIC,8,12,86,8
    EDITTEXT        IDC_FIVE_HOUR_PERCENT_EDIT,106,9,42,14,ES_NUMBER | ES_AUTOHSCROLL
    LTEXT           "5-hour reset:",IDC_STATIC,8,36,86,8
    EDITTEXT        IDC_FIVE_HOUR_RESET_EDIT,106,33,146,14,ES_AUTOHSCROLL
    LTEXT           "Weekly usage (%):",IDC_STATIC,8,60,86,8
    EDITTEXT        IDC_WEEKLY_PERCENT_EDIT,106,57,42,14,ES_NUMBER | ES_AUTOHSCROLL
    LTEXT           "Weekly reset:",IDC_STATIC,8,84,86,8
    EDITTEXT        IDC_WEEKLY_RESET_EDIT,106,81,146,14,ES_AUTOHSCROLL
    LTEXT           "Reset format: YYYY-MM-DD HH:MM:SS",IDC_STATIC,106,99,146,8
    DEFPUSHBUTTON   "OK",IDOK,144,108,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,202,108,50,14
END

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x2L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "TrafficMonitor"
            VALUE "FileDescription", "Codex Limit Monitor Plugin for TrafficMonitor"
            VALUE "FileVersion", "1.0.0.0"
            VALUE "InternalName", "CodexLimitPlugin.dll"
            VALUE "LegalCopyright", "Copyright (C) 2026"
            VALUE "OriginalFilename", "CodexLimitPlugin.dll"
            VALUE "ProductName", "Codex Limit Monitor Plugin"
            VALUE "ProductVersion", "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
